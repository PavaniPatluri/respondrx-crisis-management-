{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["backend/**"]
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn --worker-class eventlet -w 1 main:app",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/"
  }
}
